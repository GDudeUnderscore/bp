{
    "model": {
        "type": "select",
        "property": "custom_model_data",
        "fallback": {
            "type": "model",
            "model": "item/wooden_sword"
        },
        "cases": [
            {"when": "wooden_sword", "model": {"type": "model", "model": "item/swords/wooden_sword"}},
            {"when": "kelpy_cutlass", "model": {"type": "model", "model": "item/swords/kelpy_cutlass"}}
        ]
    }
}