{
    "model": {
        "type": "select",
        "property": "custom_model_data",
        "fallback": {
            "type": "model",
            "model": "item/stone_sword"
        },
        "cases": [
            {"when": "cobblestone_sword", "model": {"type": "model", "model": "item/swords/cobblestone_sword"}},
            {"when": "lament", "model": {"type": "model", "model": "item/swords/lament"}}
        ]
    }
}